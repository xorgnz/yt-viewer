{
  "name": "yt-channel-watcher",
  "private": true,
  "version": "1.0.0",
  "description": "",
  "license": "ISC",
  "author": "",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "start": "node build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:postgres": "tsx scripts/run_with_local_postgres.ts npm run dev",
    "test:postgres": "tsx scripts/run_with_local_postgres.ts npm run test",
    "db:compose:up": "docker compose up -d postgres",
    "db:compose:down": "docker compose down",
    "db:create": "tsx scripts/create_database.ts",
    "db:create:local": "tsx scripts/run_with_local_postgres.ts npm run db:create -- --mode dev",
    "db:migrate": "tsx scripts/migrate_database.ts",
    "db:migrate:local": "tsx scripts/run_with_local_postgres.ts npm run db:migrate -- --mode dev",
    "db:migrate:sqlite": "tsx scripts/migrate_sqlite_to_postgres.ts",
    "create_database": "tsx scripts/create_database.ts",
    "migrate_database": "tsx scripts/migrate_database.ts",
    "migrate_sqlite_to_postgres": "tsx scripts/migrate_sqlite_to_postgres.ts"
  },
  "dependencies": {
    "better-sqlite3": "latest",
    "pg": "^8.20.0",
    "svelte-material-ui": "latest"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.50.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.20.0",
    "sass": "^1.77.0",
    "svelte": "^5.50.0",
    "svelte-check": "^4.3.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0",
    "vite": "^7.3.1",
    "vitest": "latest"
  }
}
